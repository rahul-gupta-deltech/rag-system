# Copy this to .env for local dev — NEVER commit .env
# Run: cp .env.example .env  then fill in your values.

# ── GCP Core ─────────────────────────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id
REGION=us-central1

# ── Cloud SQL / pgvector ──────────────────────────────────────────────────────
# Connection name format: PROJECT_ID:REGION:INSTANCE_NAME
# Find it with: gcloud sql instances describe rag-pg --format="value(connectionName)"
CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:rag-pg

# When using Cloud SQL Auth Proxy (local dev):
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ragdb
DB_USER=rag_user
DB_PASSWORD=your-db-password

# ── Vertex AI ────────────────────────────────────────────────────────────────
# No API key needed — uses Application Default Credentials (ADC).
# Run: gcloud auth application-default login
# Embedding model: text-embedding-005 (768 dims, no extra config needed)

# ── LLM Model ────────────────────────────────────────────────────────────────
# Swap this one var to change models — no code changes needed.
# gemma-4-31b-it        free tier, Vertex AI Model Garden
# gemini-2.0-flash-001  GA Gemini (requires billing)
# gemini-1.5-pro-002    GA Gemini Pro (requires billing)
LLM_MODEL=gemma-4-31b-it

# ── Optional ──────────────────────────────────────────────────────────────────
# SECRET_MANAGER_SECRET_ID=rag-db-password
